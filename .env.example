NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

# Machine-to-machine: exchange for JWT (Bearer) on POST /auth/token
SERVICE_TOKEN=change-me-service-token

REDIS_HOST=localhost
REDIS_PORT=6379

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Default LLM provider: openhub (auto), openai, anthropic
AI_DEFAULT_PROVIDER=openhub

# Webhooks: secret for signing outbound payloads (HMAC)
WEBHOOK_SIGNING_SECRET=change-me-webhook-secret

# Optional: require HMAC on POST /v1/webhooks/inbound (x-inbound-signature: sha256=<hex>)
WEBHOOK_INBOUND_SECRET=

OPENAI_EMBEDDING_MODEL=text-embedding-3-small
VECTOR_DIMS=1536

# Throttle (optional overrides)
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
